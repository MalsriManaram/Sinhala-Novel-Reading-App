{
  "expo": {
    "name": "Sinhala Novels",
    "slug": "sinhala-novels",
    "version": "1.0.0",
    "scheme": "sinhalanovels",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0C10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.sinhalanovels.reader"
    },
    "android": {
      "package": "app.sinhalanovels.reader",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0B0C10"
      }
    },
    "web": { "bundler": "metro", "output": "static" },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-screen-capture",
      "expo-font"
    ],
    "experiments": { "typedRoutes": false }
  }
}
